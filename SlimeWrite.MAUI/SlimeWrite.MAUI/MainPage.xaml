<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SlimeWrite.MAUI.MainPage">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="/Assets/Images/newfile.png" Clicked="New_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/open-file.png" Clicked="Open_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/save-file.png" Clicked="Save_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/close-file.png" Clicked="Close_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/h1.png" Clicked="H1_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/h2.png" Clicked="H2_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/bold.png" Clicked="Bold_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/italic.png" Clicked="Italic_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/link.png" Clicked="Link_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/image.png" Clicked="Image_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/list.png" Clicked="List_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/table.png" Clicked="Table_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/blockquote.png" Clicked="Quote_Clicked" />
        <ToolbarItem IconImageSource="/Assets/Images/file-properties.png" Clicked="InserFilepropps_Click" />
        <ToolbarItem Text="Options" Clicked="AppOptions_Click" />
        <ToolbarItem Text="About" Clicked="About_Click" />
    </ContentPage.ToolbarItems>

        <!-- Single Content child: a Grid that hosts the editor and preview sections -->
    <Grid RowDefinitions="0.5*,0.5*">
        <!-- Editor section (top) -->
        <StackLayout Grid.Row="0">
            <Editor x:Name="editor" Margin="4" BackgroundColor="Aqua" />
        </StackLayout>

        <!-- Preview section (bottom) -->
        <ScrollView Grid.Row="1">
            <StackLayout>
                <WebView x:Name="preview" Margin="4" BackgroundColor="Green" HeightRequest="500" 
                         WidthRequest="500" />
            </StackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
