<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SlimeWrite.Avalonia.OptionsView"
        Title="OptionsView">
  <DockPanel LastChildFill="True">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" >
      <CheckBox Name="cbxUseTextChangedEvent">Use Text Changed Event</CheckBox>
      <CheckBox Name="cbxUseEnterPressedEvent">Use Enter Pressed Event</CheckBox>
      <ComboBox SelectedIndex="0" MaxDropDownHeight="100">
        <ComboBoxItem>Text Item 1</ComboBoxItem>

      </ComboBox>
      
    </StackPanel>

  </DockPanel>
</Window>
