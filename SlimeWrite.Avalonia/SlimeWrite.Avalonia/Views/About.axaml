<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SlimeWrite.Avalonia.About"
         Width="400" Height="400"
        Title="About"   CanResize="False"
        WindowStartupLocation="CenterOwner"> 
    <!-- <Border  CornerRadius="8"  BorderBrush="#DDD" BorderThickness="1">-->
        <StackPanel    HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="10"   Margin="0,50,0,0">
            <StackPanel Orientation="Horizontal"    >
                <Image x:Name="LogoImage" Width="64" Height="64"   Stretch="Uniform"
                       Source="/Assets/Images/logo.png"
                        />
                <StackPanel Orientation="Vertical" Spacing="10" >
                    <TextBlock x:Name="AppNameText" Text="MyApp" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="VersionText" Text="Έκδοση 1.0.0" FontSize="12" Opacity="0.8" />
                </StackPanel>
            </StackPanel>

            <TextBlock Name="DescriptionText" TextWrapping="Wrap"   >
                Description
            </TextBlock>

            <StackPanel Orientation="Vertical"  >
                <TextBlock>
                    <Run>Web Site: </Run>
                    <!--<Hyperlink Click="WebsiteHyperlink_Click" />https://github.com/angaratosurion/SlimeWrite</Hyperlink>-->
                </TextBlock>
                <TextBlock   Name="CopyRightText">© 2025 .</TextBlock>
            </StackPanel>

            <Expander Header="Contributors  and License" IsExpanded="False"  >
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" >Contributors: Angarato Surion</TextBlock>
                    <TextBlock TextWrapping="Wrap" > License: GNU GENERAL PUBLIC LICENSE v3</TextBlock>
                </StackPanel>
            </Expander>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!--<Button Margin="0 0 8 0" Padding="10,4" Click="CopyInfo_Click">Αντιγραφή Πληροφοριών</Button> -->
                <Button Padding="10,4" IsDefault="True" 
                        Click="Close_Click">Close</Button>
            </StackPanel>
        </StackPanel>
    <!--</Border>-->
</Window>
