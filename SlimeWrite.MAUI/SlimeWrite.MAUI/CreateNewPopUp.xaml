<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SlimeWrite.MAUI.CreateNewDocumentPopUp"
                xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                xmlns:system="clr-namespace:System;assembly=netstandard"
                x:TypeArguments="system:String" BackgroundColor="Black">
    <VerticalStackLayout>
        <Label Text="Give a name for the new document" />
        <Entry x:Name="DocumentName" Placeholder="Document Name"/>

        <Button Text="OK" Clicked="OnOkClicked"/>
    </VerticalStackLayout>
</toolkit:Popup>