<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SlimeWrite.PluginsList"
             Title="List of Plugins">
    <VerticalStackLayout>
        <CollectionView x:Name="PluginsCollectionView" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" 
                           CornerRadius="5" Padding="10" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="Medium"/>
                            <Label Text="{Binding Version}" FontSize="Small"/>
                            <Label Text="{Binding Author}" FontSize="Small" Opacity="0.8"/>
                            <Label Text="{Binding Description}" FontSize="Small" Opacity="0.8"/>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>