<ItemGroup>
<MauiIconInclude="Resources\AppIcon\appicon.svg"ForegroundFile="Resources\AppIcon\appiconfg.svg"Color="#512BD4"/>
<MauiSplashScreenInclude="Resources\Splash\splash.svg"Color="#512BD4"BaseSize="128,128"/>
