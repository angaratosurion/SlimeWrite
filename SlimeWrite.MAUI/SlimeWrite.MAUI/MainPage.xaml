<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SlimeWrite.MAUI.MainPage">

    <ContentPage.ToolbarItems >
        <ToolbarItem IconImageSource="newfile.png" Clicked="New_Clicked" />
        <ToolbarItem IconImageSource="openfile.png" Clicked="Open_Clicked" />
        <ToolbarItem IconImageSource="savefile.png" Clicked="Save_Clicked" />
        <ToolbarItem IconImageSource="closefile.png" Clicked="Close_Clicked" />
        <ToolbarItem IconImageSource="h1.png" Clicked="H1_Clicked" />
        <ToolbarItem IconImageSource="h2.png" Clicked="H2_Clicked" />
        <ToolbarItem IconImageSource="bold.png" Clicked="Bold_Clicked" />
        <ToolbarItem IconImageSource="italic.png" Clicked="Italic_Clicked" />
        <ToolbarItem IconImageSource="link.png" Clicked="Link_Clicked" />
        <ToolbarItem IconImageSource="image.png" Clicked="Image_Clicked" />
        <ToolbarItem IconImageSource="list.png" Clicked="List_Clicked" />
        <ToolbarItem IconImageSource="table.png" Clicked="Table_Clicked" />
        <ToolbarItem IconImageSource="blockquote.png" Clicked="Quote_Clicked" />
        <ToolbarItem IconImageSource="fileproperties.png" Clicked="InserFilepropps_Click" />
        <ToolbarItem Text="Options" Clicked="AppOptions_Click" />
        <ToolbarItem Text="About" Clicked="About_Click" />
    </ContentPage.ToolbarItems>

        <!-- Single Content child: a Grid that hosts the editor and preview sections -->
    <Grid RowDefinitions="0.5*,0.01*,0.5*"  >
        <!-- Editor section (top) -->
        <StackLayout Grid.Row="0" >
            <Editor x:Name="editor" Margin="4" BackgroundColor="Aqua"  MinimumHeightRequest="400"   />
        </StackLayout>
        <Slider HorizontalOptions="Fill" Grid.Row="1" Margin="4" MinimumHeightRequest="20"  />

        <!-- Preview section (bottom) -->
        <ScrollView Grid.Row="2">
            <StackLayout>
                <WebView x:Name="preview" Margin="4" BackgroundColor="Green"  MinimumHeightRequest="500" 
                         WidthRequest="500" />
            </StackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
