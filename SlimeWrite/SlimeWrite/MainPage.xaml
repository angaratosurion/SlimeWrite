<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SlimeWrite.MainPage" SizeChanged="ContentPage_SizeChanged"
             Loaded="ContentPage_Loaded" Unloaded="ContentPage_Unloaded" 
             Appearing="ContentPage_Appearing" 
              >
    <VerticalStackLayout Spacing="0">
        <!-- TOOLBAR -->
        <ScrollView Orientation="Vertical">
            <FlexLayout  x:Name="Toolbar"
        Wrap="Wrap"
        Direction="Row"
        JustifyContent="Start"
        AlignItems="Start"
        Padding="5">

                <!-- File -->
                <ImageButton Source="newfile.png" WidthRequest="40" 
                             HeightRequest="40" Clicked="New_Clicked" 
                             x:Name="btnNewFile"/>
                <ImageButton Source="openfile.png" 
                             WidthRequest="40" HeightRequest="40"
                             Clicked="Open_Clicked" x:Name="btnOpenFile"/>
                <ImageButton Source="savefile.png" WidthRequest="40" HeightRequest="40" Clicked="Save_Clicked" x:Name="btnSaveFile"/>
                <ImageButton Source="closefile.png" WidthRequest="40" HeightRequest="40" Clicked="Close_Clicked" x:Name="btnCloseFile"/>

                <!-- Headings -->
                <ImageButton Source="h1.png" WidthRequest="40" HeightRequest="40" Clicked="H1_Clicked" x:Name="btnH1"/>
                <ImageButton Source="h2.png" WidthRequest="40" HeightRequest="40" Clicked="H2_Clicked" x:Name="btnH2"/>

                <!-- Formatting -->
                <ImageButton Source="bold.png" WidthRequest="40" HeightRequest="40" Clicked="Bold_Clicked" x:Name="btnBold"/>
                <ImageButton Source="italic.png" WidthRequest="40" HeightRequest="40" Clicked="Italic_Clicked" x:Name="btnItalic"/>

                <!-- Insert -->
                <ImageButton Source="link.png" WidthRequest="40" HeightRequest="40" Clicked="Link_Clicked" x:Name="btnLink"/>
                <ImageButton Source="image.png" WidthRequest="40" HeightRequest="40" Clicked="Image_Clicked" x:Name="btnImage"/>
                <ImageButton Source="list.png" WidthRequest="40" HeightRequest="40" Clicked="List_Clicked" x:Name="btnList"/>
                <ImageButton Source="table.png" WidthRequest="40" HeightRequest="40" Clicked="Table_Clicked" x:Name="btnTable"/>
                <ImageButton Source="blockquote.png" 
                             WidthRequest="40" HeightRequest="40" 
                             Clicked="Quote_Clicked" x:Name="btnQuote"/>
                <ImageButton Source="fileimport.png" 
             WidthRequest="40" HeightRequest="40" 
              Clicked="ImportFile_Clicked" x:Name="btnImportFile"/>

                <!-- Extras -->
                <ImageButton Source="fileproperties.png" WidthRequest="40" 
                             HeightRequest="40" Clicked="InserFilepropps_Click"
                             x:Name="btnFileProperties"/>

                <Button Text="Options" Clicked="AppOptions_Click"
                        x:Name="btnOptions"/>
                <Button Text="About" Clicked="About_Click" 
                        x:Name="btnAbout"/>

            </FlexLayout>
        </ScrollView>





        <!-- Single Content child: a Grid that hosts the editor and preview sections -->
        <Grid x:Name="MainGrid"    VerticalOptions="Fill"
          >
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition x:Name="BottomRow" Height="*" />
            </Grid.RowDefinitions>
            <!-- Editor section (top) -->
            <ScrollView Grid.Row="0" HorizontalScrollBarVisibility="Always"
                    VerticalScrollBarVisibility="Always" 
                    x:Name="scrollview"
                     >
                <!--<StackLayout Grid.Row="0" >-->
                <Editor x:Name="editor" Margin="4"  
                    VerticalOptions="Fill"
                HorizontalOptions="Fill" IsSpellCheckEnabled="True"
                        IsTextPredictionEnabled="True"   
                        Completed="editor_Completed"
                        />
                <!-- </StackLayout>-->
            </ScrollView>
            <!-- Splitter -->
            <BoxView Grid.Row="1" BackgroundColor="DarkGray"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" x:Name="spliter"
                >
                <BoxView.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPanUpdated"/>

                </BoxView.GestureRecognizers>

            </BoxView>

            <!-- Preview section (bottom) -->
            <ScrollView Grid.Row="2">
                <StackLayout>
                    <WebView x:Name="preview" Margin="4"   MinimumHeightRequest="300" 
                         WidthRequest="500" VerticalOptions="Fill"
                HorizontalOptions="Fill" />
                </StackLayout>
            </ScrollView>
        </Grid>
    </VerticalStackLayout>
</ContentPage>