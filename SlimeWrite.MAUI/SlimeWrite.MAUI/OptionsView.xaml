<ContentPage  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
        x:Class="SlimeWrite.MAUI.Views.OptionsView" 
        Title="Options"
        Width="600"
        Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <DockLayout LastChildFill="True">
    <StackLayout DockLayout.Dock="Top" Orientation="Vertical"   >
      <StackLayout DockLayout.Dock="Top" Orientation="Horizontal" Margin="4" >
        <CheckBox Name="cbxUseTextChangedEvent">Use Text Changed Event</CheckBox>
        <CheckBox Name="cbxUseEnterPressedEvent">Use Enter Pressed Event</CheckBox>
        <CheckBox Name="cbxUseUpdateFromGitHub">Update Using GitHub</CheckBox>

      </StackLayout>
      <Label>WebView Orientation</Label>
      
      <ComboBox SelectedIndex="0" MaxDropDownHeight="100" Name ="cmbxOrientation">

        <ComboBoxItem>Vertical</ComboBoxItem>
        <ComboBoxItem>Horizontal</ComboBoxItem>

      </ComboBox>
      <StackLayout DockLayout.Dock="Bottom" Orientation="Horizontal" Margin="100" Spacing="10">
        <Button Click="Close_Click">Cancel</Button>
        <Button Click="Save_Click">Save</Button>

      </StackLayout>
    </StackLayout>

  </DockLayout>
</ContentPage>
